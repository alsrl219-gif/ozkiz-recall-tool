# ─── 이지어드민 ──────────────────────────────────────────────────
EZADMIN_URL=https://your-company.ezadmin.co.kr
EZADMIN_ID=your_id
EZADMIN_PW=your_password

# ─── 이지체인 ────────────────────────────────────────────────────
EZCHAIN_URL=https://your-company.ezchain.co.kr
EZCHAIN_ID=your_id
EZCHAIN_PW=your_password

# ─── 쿠팡 Wing ──────────────────────────────────────────────────
COUPANG_ID=your_coupang_id
COUPANG_PW=your_coupang_password
COUPANG_VENDOR_ID=A00012345

# ─── 분석 설정 ──────────────────────────────────────────────────
# 판매 통계 집계 기간 (일)
ANALYSIS_PERIOD_DAYS=30

# ─── 스케줄 (cron 표현식) ────────────────────────────────────────
# 기본: 매일 오전 6시
CRON_SCHEDULE=0 6 * * *

# ─── 서버 포트 ──────────────────────────────────────────────────
PORT=3001

# ─── 파일 저장 경로 ─────────────────────────────────────────────
# 다운로드된 CSV 임시 저장 폴더
DOWNLOAD_DIR=./downloads
# 처리된 데이터 저장 경로
DATA_OUTPUT=./data/latest.json

# ─── 브라우저 설정 ──────────────────────────────────────────────
# true = 백그라운드 실행 (서버용), false = 창 보이게 (디버그용)
HEADLESS=true
